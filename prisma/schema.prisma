generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  brand           String?
  image_url       String?
  price           Decimal?       @db.Decimal(10, 2)
  volume          Decimal?       @db.Decimal(10, 4)
  total_volume    Decimal?       @db.Decimal(10, 4)
  unit_price      Decimal?       @db.Decimal(10, 4)
  source_url      String?
  raw_description String?
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  priceHistory    PriceHistory[]

  @@map("products")
}

model PriceHistory {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id  String    @db.Uuid
  price       Decimal   @db.Decimal(10, 2)
  source_url  String?
  recorded_at DateTime? @default(now()) @db.Timestamptz(6)
  product     Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_price_history_product_id")
  @@map("price_history")
}
